# Copy this file to `.env.local` in this directory and fill in values.
#   Windows (PowerShell):  Copy-Item .env.example .env.local
#   Unix:                   cp .env.example .env.local
#
# ========== App URL ==========
# Local: http://localhost:3000  |  Production: your real https URL
NEXTAUTH_URL="http://localhost:3000"
# Used by NextAuth; generate: openssl rand -base64 32
NEXTAUTH_SECRET="paste-a-long-random-string"

# Optional: public site base (e.g. ConvertKit referrer, emails)
# NEXT_PUBLIC_SITE_URL="http://localhost:3000"
# NEXT_PUBLIC_SUPPORT_EMAIL="you@example.com"

# ========== Database (required) ==========
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ========== Sign-in: pick at least one ==========
# Google OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email magic link — Resend (optional; see lib/authOptions if using SMTP only)
# RESEND_API_KEY=""
# EMAIL_FROM="onboarding@resend.dev"
# If using SMTP instead, see EMAIL_SERVER in authOptions

# ========== Free-tier analysis quota (recommended for local so /api/analysis/quota works) ==========
# Vercel KV (REST) or Upstash Redis — use one pair
# KV_REST_API_URL="https://xxx.upstash.io"
# KV_REST_API_TOKEN="..."
#   OR
# UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
# UPSTASH_REDIS_REST_TOKEN="..."

# ========== Email list / gate (for /api/subscribe) ==========
CONVERTKIT_API_KEY=""
CONVERTKIT_FORM_ID="123456"
# CONVERTKIT_TAG_ID=""
# CONVERTKIT_SUBSCRIBE_REFERRER=""

# ---------------------------------------------------------------------------
# PayPal — ONE-TIME $29 (current app flow)
# ---------------------------------------------------------------------------
# You do NOT need PAYPAL_PLAN_ID for this. You do NOT need to create a
# "Subscription plan" (P-...) or a hosted PayPal button in the dashboard.
# Create a REST "app" in PayPal Developer Dashboard → get Sandbox (or Live)
# Client ID + Secret. Our server creates the order and amount via API.
#
# PAYPAL_MODE=sandbox   (use sandbox keys)  |  live  (use live keys)
PAYPAL_MODE="sandbox"

# Public client id (loaded in the browser for the JS SDK)
NEXT_PUBLIC_PAYPAL_CLIENT_ID="..."

# Server secret (never expose to the browser)
PAYPAL_CLIENT_SECRET="..."

# Optional: same as NEXT_PUBLIC_ if you only set one
# PAYPAL_CLIENT_ID="..."

# Optional: charge amount in USD (default 29 in code)
# Keep server + UI in sync if you set both
PAYPAL_ONETIME_USD="29"
NEXT_PUBLIC_PAYPAL_ONETIME_USD="29"

# Webhook: optional for LOCAL testing (capture runs via your browser + /api/paypal/capture-order)
# Add when you deploy: create webhook in dashboard → your-site/api/paypal/webhook
# and subscribe to PAYMENT.CAPTURE.COMPLETED; put Webhook ID here
# PAYPAL_WEBHOOK_ID="..."

# ---------------------------------------------------------------------------
# PayPal — LEGACY MONTHLY SUBSCRIPTION (only if you still use old API routes)
# ---------------------------------------------------------------------------
# If you are NOT using subscription checkout anymore, you can OMIT or leave empty.
# Only needed for GET /api/paypal/subscription-plan and POST /api/paypal/verify-subscription.
# PAYPAL_PLAN_ID="P-..."
